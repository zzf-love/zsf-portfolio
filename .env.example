# ============================================================
# 数据库配置（SQLite，开发环境使用）
# ============================================================
DATABASE_URL="file:./prisma/portfolio.db"

# ============================================================
# 管理员认证
# ============================================================
# 管理员登录密码（自定义一个强密码）
ADMIN_PASSWORD="your-strong-admin-password-here"

# JWT 签名密钥（随机字符串，至少32位）
JWT_SECRET="your-random-jwt-secret-key-at-least-32-chars"

# ============================================================
# Cloudinary 图片托管
# 注册地址：https://cloudinary.com
# 在 Dashboard 找到 Cloud Name / API Key / API Secret
# ============================================================
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# ============================================================
# Anthropic Claude API
# 获取地址：https://console.anthropic.com
# ============================================================
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# ============================================================
# Next.js 配置
# 生产环境改为实际域名，如：https://yoursite.vercel.app
# ============================================================
NEXTAUTH_URL="http://localhost:3000"
